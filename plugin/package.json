{
    "name": "zotero-pdf2zh-next",
    "version": "4.0.3",
    "description": "Minimal Zotero bridge for pdf2zh_next",
    "config": {
        "addonName": "zotero-pdf2zh-next",
        "addonID": "zotero-pdf2zh-next@nightwatcher.local",
        "addonRef": "pdf2zhnext",
        "addonInstance": "pdf2zhnext",
        "prefsPrefix": "extensions.zotero.pdf2zhnext"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/NightWatcher314/zotero-pdf2zh-next.git"
    },
    "author": "NightWatcher",
    "bugs": {
        "url": "https://github.com/NightWatcher314/zotero-pdf2zh-next/issues"
    },
    "homepage": "https://github.com/NightWatcher314/zotero-pdf2zh-next#readme",
    "license": "AGPL-3.0-or-later",
    "scripts": {
        "start": "zotero-plugin serve",
        "build": "tsc --noEmit && zotero-plugin build",
        "lint:check": "prettier --check . && eslint .",
        "lint:fix": "prettier --write . && eslint . --fix",
        "release": "zotero-plugin release",
        "test": "echo \"Error: no test specified\" && exit 1",
        "update-deps": "pnpm up --latest"
    },
    "dependencies": {
        "zotero-plugin-toolkit": "5.1.0-beta.10"
    },
    "devDependencies": {
        "@eslint/js": "^9.22.0",
        "@types/node": "^22.13.10",
        "axios": "^1.8.2",
        "eslint": "^9.22.0",
        "form-data": "^4.0.2",
        "path": "^0.12.7",
        "prettier": "^3.5.3",
        "typescript": "^5.8.2",
        "typescript-eslint": "^8.26.0",
        "zotero-plugin-scaffold": "^0.3.2",
        "zotero-types": "^4.1.0-beta.4",
        "@napi-rs/canvas": "^0.1.80"
    },
    "prettier": {
        "printWidth": 80,
        "tabWidth": 4,
        "endOfLine": "lf",
        "overrides": [
            {
                "files": [
                    "*.xhtml"
                ],
                "options": {
                    "htmlWhitespaceSensitivity": "css"
                }
            }
        ]
    }
}
